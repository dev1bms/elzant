# Production environment for elzant.com — copy to /srv/elzant/.env and fill in.
# Generate SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=PUT-A-GENERATED-SECRET-KEY-HERE
DEBUG=False
ALLOWED_HOSTS=elzant.com,www.elzant.com
CSRF_TRUSTED_ORIGINS=https://elzant.com,https://www.elzant.com
SITE_URL=https://elzant.com

# Persistent, backed-up location for the SQLite database file.
SQLITE_PATH=/srv/elzant/data/db.sqlite3

# Persistent, backed-up location for user-uploaded greeting photos.
MEDIA_ROOT=/srv/elzant/media

# Let Django serve /media/ itself. Set to True ONLY when Gunicorn runs directly
# behind Cloudflare Tunnel with no file-serving proxy. Leave False when Caddy or
# Nginx serves /media/ (see deploy/DEPLOY.md → "Media").
SERVE_MEDIA=False
