# Production environment for elzant.com — copy to /srv/elzant/.env and fill in.
# Generate SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=PUT-A-GENERATED-SECRET-KEY-HERE
DEBUG=False
ALLOWED_HOSTS=elzant.com,www.elzant.com
CSRF_TRUSTED_ORIGINS=https://elzant.com,https://www.elzant.com
SITE_URL=https://elzant.com

# Persistent, backed-up location for the SQLite database file.
SQLITE_PATH=/srv/elzant/data/db.sqlite3

# Persistent, backed-up location for user-uploaded greeting photos.
MEDIA_ROOT=/srv/elzant/media

# Django serves /media/ itself by default (SERVE_MEDIA defaults to True) so photos
# work out of the box. Set to False ONLY if Caddy/Nginx serves /media/ for you
# (see deploy/DEPLOY.md → "Media").
# SERVE_MEDIA=True

# --- WhatsApp Cloud API (invitations). SECRETS ONLY — never commit real values.
# Operational settings live in the admin (WhatsAppConfig). Blank = safe mode.
WHATSAPP_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_API_VERSION=v21.0
