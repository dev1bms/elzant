# Copy this file to .env and fill in real values. Never commit .env.
# THIS IS THE LOCAL-DEVELOPMENT TEMPLATE (DEBUG=True, empty ALLOWED_HOSTS).
# For the server, start from deploy/.env.production.example instead.
# ------------------------------------------------------------------

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# Debug mode. Keep True for local development, False in production.
DEBUG=True

# Comma-separated hosts allowed to serve the site (production only).
# Example: ALLOWED_HOSTS=elzant.com,www.elzant.com
ALLOWED_HOSTS=

# Comma-separated trusted origins for CSRF (production, scheme required).
# Example: CSRF_TRUSTED_ORIGINS=https://elzant.com,https://www.elzant.com
CSRF_TRUSTED_ORIGINS=

# Canonical site URL — used for Open Graph absolute URLs (og:url, og:image).
# Example: SITE_URL=https://elzant.com
SITE_URL=http://127.0.0.1:8000

# --- WhatsApp Cloud API (invitations): NO env vars needed.
# All settings AND secrets (token, app secret, verify token, api version) are
# managed from the admin → «إعدادات واتساب» (WhatsAppConfig): masked + superuser-only.
# Step-by-step visual guide: docs/whatsapp-setup-guide.html
