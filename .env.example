# Copy this file to .env and fill in real values. Never commit .env.
# ------------------------------------------------------------------

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me

# Debug mode. Keep True for local development, False in production.
DEBUG=True

# Comma-separated hosts allowed to serve the site (production only).
# Example: ALLOWED_HOSTS=elzant.com,www.elzant.com
ALLOWED_HOSTS=

# Comma-separated trusted origins for CSRF (production, scheme required).
# Example: CSRF_TRUSTED_ORIGINS=https://elzant.com,https://www.elzant.com
CSRF_TRUSTED_ORIGINS=

# Canonical site URL — used for Open Graph absolute URLs (og:url, og:image).
# Example: SITE_URL=https://elzant.com
SITE_URL=http://127.0.0.1:8000

# --- WhatsApp Cloud API (invitations) — secrets live here ONLY, never in the DB.
# Operational settings (phone_number_id, template name, on/off) live in the admin
# (WhatsAppConfig). Leave blank to keep the invitation layer in safe mode.
# Long-lived access token for the WhatsApp Business system user.
WHATSAPP_TOKEN=
# App Secret — used to verify Meta's webhook HMAC-SHA256 signature.
WHATSAPP_APP_SECRET=
# Your own random string; must match the "Verify Token" set in Meta's webhook UI.
WHATSAPP_VERIFY_TOKEN=
# Graph API version (optional; defaults to v21.0).
# WHATSAPP_API_VERSION=v21.0
